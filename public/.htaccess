# cPanel / Apache config for SproutPay SPA

# 1) Proxy /api/* to the backend so the browser sees same-origin (no CORS).
#    Requires mod_proxy + mod_proxy_http enabled on the cPanel host.
<IfModule mod_proxy.c>
  SSLProxyEngine on
  ProxyPreserveHost Off
  ProxyPass        /api/  https://po1--sproutvest-login--z2lspzgvtzdk.code.run/api/
  ProxyPassReverse /api/  https://po1--sproutvest-login--z2lspzgvtzdk.code.run/api/
</IfModule>

# 2) SPA fallback: send every non-file, non-/api request to index.html
#    so deep links like /login work on refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't touch real files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Don't touch /api/* (handled by mod_proxy above)
  RewriteRule ^api/ - [L]

  # Everything else -> SPA
  RewriteRule ^ index.html [L]
</IfModule>

# Cache hashed assets aggressively
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
